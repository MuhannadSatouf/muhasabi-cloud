generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  currency  String   @default("SYP")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  accounts Account[]
}

enum UserRole {
  OWNER
  ACCOUNTANT
  VIEWER
}

model User {
  id             String   @id @default(cuid())
  companyId      String
  email          String
  hashedPassword String
  name           String
  role           UserRole @default(OWNER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model Account {
  id        String      @id @default(cuid())
  companyId String
  code      String
  name      String
  nameAr    String?
  type      AccountType
  isSystem  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
}